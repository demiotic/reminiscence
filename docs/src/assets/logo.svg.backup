<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#a855f7;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#9333ea;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Cubo en perspectiva isométrica -->
  <!-- Cara superior -->
  <path d="M 100,60 L 140,80 L 100,100 L 60,80 Z" 
        fill="url(#grad)" opacity="0.95"/>
  
  <!-- Cara izquierda -->
  <path d="M 60,80 L 60,120 L 100,140 L 100,100 Z" 
        fill="#06b6d4" opacity="0.9"/>
  
  <!-- Cara derecha -->
  <path d="M 100,100 L 100,140 L 140,120 L 140,80 Z" 
        fill="#3b82f6" opacity="0.9"/>
  
  <!-- Bordes del cubo -->
  <g stroke="#1e293b" stroke-width="2.5" fill="none" stroke-linejoin="round" stroke-linecap="round">
    <path d="M 100,60 L 140,80 L 100,100 L 60,80 Z"/>
    <path d="M 60,80 L 60,120 L 100,140 L 140,120 L 140,80"/>
  </g>
</svg>